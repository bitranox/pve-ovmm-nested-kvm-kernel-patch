+++ b/arch/x86/kvm/vmx/nested.c
@@ -3540,7 +3540,7 @@ static bool vmx_get_nested_state_pages(struct kvm_vcpu *vcpu)
 	/*
 	 * Note: nested_get_evmcs_page() also updates 'vp_assist_page' copy
